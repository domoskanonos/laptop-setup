# Kopiere diese Datei nach .env und passe die Werte an
# cp .env.example .env
# Nur folgende Variablen werden vom Setup akzeptiert (Whitelist)
# Keine Command-Substitution oder Bash-Logik in diese Datei schreiben

# Git-Konfiguration
GIT_USER_NAME="Dominik Bruhn"
GIT_USER_EMAIL="domoskanonos@googlemail.com"

# SSH-Schluessel
SSH_KEY_PATH="$HOME/.ssh/id_ed25519"

# Ollama Standardmodell
OLLAMA_DEFAULT_MODEL="qwen3.5:4b"

# Hermes Dashboard (GUI im Netzwerk)
# Fuer LAN-Zugriff z. B. 0.0.0.0 verwenden
HERMES_DASHBOARD_HOST="0.0.0.0"
HERMES_DASHBOARD_PORT="9119"

# Basic-Auth fuer das Dashboard
# Wenn Passwort/Secret leer bleiben, erzeugt setup.sh sichere Werte in ~/.hermes/.env
HERMES_DASHBOARD_BASIC_AUTH_USERNAME="admin"
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=""
HERMES_DASHBOARD_BASIC_AUTH_SECRET=""
