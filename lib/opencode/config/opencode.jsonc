{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "mcp_timeout": 3600000
  },
  "mcp": {
    "quisy-tts": {
      "enabled": true,
      "type": "remote",
      "url": "http://127.0.0.1:8045/interface/mcp"
    },
    "comfyui": {
      "command": [
        "npx",
        "comfyui-mcp"
      ],
      "enabled": true,
      "environment": {},
      "type": "local"
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}"
      }
    },
    "mcp-pandoc": {
      "command": [
        "uvx",
        "mcp-pandoc"
      ],
      "enabled": true,
      "environment": {},
      "type": "local"
    },
    "memory": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "environment": {
        "MEMORY_FILE_PATH": "./memory.jsonl"
      },
      "enabled": true,
      "type": "local"
    },
    "open-websearch": {
      "command": [
        "npx",
        "-y",
        "open-websearch"
      ],
      "environment": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo"
      },
      "enabled": true,
      "type": "local"
    },
    "sqlite-tools": {
      "command": [
        "npx",
        "-y",
        "mcp-sqlite-tools"
      ],
      "enabled": true,
      "environment": {
        "SQLITE_ALLOW_ABSOLUTE_PATHS": "true",
        "SQLITE_BACKUP_PATH": "./backups",
        "SQLITE_DEFAULT_PATH": "."
      },
      "type": "local"
    }
  },
  "permission": {
    "*": "allow",
    "google_search": "deny"
  },
  "plugin": [],
  "agent": {
    "build": {
      "steps": 25,
      "model": "opencode/deepseek-v4-flash-free"
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "qwen3.5:4b": {
          "maxTokens": 32768,
          "name": "qwen3.5:4b",
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "tool_call": true
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "opencode": {
      "name": "OpenCode Zen",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1"
      },
      "models": {
        "deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash Free",
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 32768
          }
        }
      }
    }
  }
}